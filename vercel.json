{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "crons": [
    {
      "path": "/api/cron/rss?source=cron",
      "schedule": "0 12 * * *"
    },
    {
      "path": "/api/cron/wikipedia?source=cron",
      "schedule": "0 13 * * *"
    },
    {
      "path": "/api/cron/gdelt?source=cron",
      "schedule": "0 14 * * *"
    }
  ],
  "functions": {
    "api/cron/wikipedia.js": { "maxDuration": 60 },
    "api/cron/rss.js": { "maxDuration": 60 },
    "api/cron/gdelt.js": { "maxDuration": 60 }
  }
}
